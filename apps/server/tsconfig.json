{
  "compilerOptions": {
    "target": "ESNext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "./dist",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
  },
  "include": [
    "./src/**/*",
    "./tsdown.config.ts",
    "./tests/**/*",
    "./migrations/**/*.ts",
    "./drizzle.config.ts",
    "./vitest.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}